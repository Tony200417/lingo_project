rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Progress collection rules
    match /progress/{userId} {
      // For this specific app, we allow read/write if authenticated
      // or if the userId matches the document ID (which is the username)
      // Since we use a custom login, we'll allow public read/write for now
      // but ideally we'd use Firebase Auth.
      allow read, write: if true; 
    }
  }
}
